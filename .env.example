# ============================================================
# Enterprise Agentic RAG — Environment Configuration
# ============================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ============================================================

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_rag
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password_dev
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# === Milvus (Vector Store) ===
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=enterprise_kb
MILVUS_DIMENSION=1024

# === Elasticsearch (Full-Text / BM25 + IK Analyzer) ===
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=enterprise_kb

# === MinIO (Object Storage) ===
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=${MINIO_HOST}:${MINIO_PORT}
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev
MINIO_BUCKET=enterprise-rag-docs
MINIO_SECURE=false

# === OpenTelemetry ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=enterprise-agentic-rag
OTEL_ENABLED=false

# === Prometheus ===
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# === Grafana ===
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_dev

# === LLM Provider ===
LLM_PROVIDER=mock
LLM_MODEL=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# === LLM Provider (legacy keys — still supported) ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=

# === Embedding ===
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=mock-embedding
EMBEDDING_DIMENSIONS=768

# === Application ===
LOG_LEVEL=INFO
MAX_RETRIES=3
RETRIEVAL_K=5
MAX_TOKENS_CONTEXT=8192
MAX_TOKENS_RESPONSE=2048

# === LangSmith (Observability) ===
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=enterprise-agentic-rag

# ============================================================
# Graph RAG — Neo4j Knowledge Graph
# ============================================================
ENABLE_GRAPH_RAG=true
GRAPH_ENGINE=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
GRAPH_DEPTH=2
GRAPH_TOP_K=30

# === Retrieval Router ===
ENABLE_DYNAMIC_ROUTER=true
DEFAULT_RETRIEVAL_MODE=parallel
ENABLE_GRAPH_FIRST=true
ENABLE_KEYWORD_FIRST=true
ENABLE_VECTOR_FIRST=true
ENABLE_HYBRID_FALLBACK=true

# === Graph Fusion ===
ENABLE_GRAPH_FUSION=true
GRAPH_WEIGHT_DEFAULT=0.2
FUSION_METHOD=rrf
RRF_K=60

# === Docker ===
USE_LOCAL_DOCKER_IMAGES=true
FORCE_PULL_IMAGES=false
